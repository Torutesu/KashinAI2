# --- Core ---
DATABASE_URL="file:./dev.db"
PORT=3001

# --- LLM ---
# Provider selection: gemini (default) | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_google_gemini_api_key
# Only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Point at any OpenAI-compatible server for a local LLM (e.g. Ollama):
#   OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=

# --- Security (P0) ---
# Token required on state-changing routes (/chat, /actions/execute,
# /memory/store, /voice/query). If unset, those routes run UNAUTHENTICATED
# and the server logs a warning — set this before any non-local use.
# Also store it in the Chrome extension: chrome.storage.local.set({ kashinaiToken: '<token>' })
API_TOKEN=

# Optional multi-device tokens: comma-separated label:token pairs, one per
# device. Combined with API_TOKEN. Revoke a device by removing its pair and
# restarting. e.g. laptop:abc123,phone:def456
API_TOKENS=

# Comma-separated CORS origin allowlist (e.g. chrome-extension://<id>).
# If unset, all origins are allowed (the API_TOKEN gate is the real boundary).
ALLOWED_ORIGINS=

# Set to "true" to disable capture-time secret redaction (not recommended).
DISABLE_SECRET_REDACTION=

# Comma-separated app names (case-insensitive substrings). While one of these
# apps is focused, collectors pause capture (clipboard, screen OCR, selected
# text, app activity). e.g. 1Password,Bitwarden,Keychain
CAPTURE_EXCLUDE_APPS=

# Per-IP rate limiting. RATE_LIMIT_MAX=0 disables it.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# --- Integrations ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# Optional: user token (xoxp-…) required only for Slack message search.
SLACK_USER_TOKEN=
GITHUB_TOKEN=
NOTION_API_KEY=

# Jira Cloud (email + API token from id.atlassian.com)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Linear (personal API key)
LINEAR_API_KEY=

# Google Drive read uses the same Google OAuth — re-run src/auth/googleAuth.ts
# after this update so the drive.readonly scope is granted.

# Optional: IANA timezone (e.g. Asia/Tokyo) applied to created/updated
# calendar events so bare datetimes aren't interpreted ambiguously.
CALENDAR_TIMEZONE=

# Optional overrides for Google credential/token file locations.
# GOOGLE_CREDENTIALS_PATH=
# GOOGLE_TOKEN_PATH=

# --- Logging (optional) ---
# LOG_LEVEL: debug | info | warn | error (default info)
LOG_LEVEL=info
# LOG_FORMAT=json emits one JSON object per line (default: readable text)
LOG_FORMAT=

# --- Memory retention (optional) ---
# Days to keep collected memories before pruning (default 30; 0 disables).
MEMORY_RETENTION_DAYS=30

# --- Voice (optional) ---
# WHISPER_MODEL=Xenova/whisper-base
# WHISPER_LANGUAGE=
