{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KashinAI2",
  "version": "1.7.0",
  "identifier": "com.torutesu.kashinai2",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KashinAI2",
        "width": 1180,
        "height": 820,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/engine": "engine"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
